using UnityEngine;

public class GameManager : MonoBehaviour
{
    public static GameManager instance;

    public int soulPoints = 50;
    public bool gameOver = false;

    void Awake()
    {
        if (instance == null)
            instance = this;
    }

    public void ModifySoul(int amount)
    {
        soulPoints += amount;

        Debug.Log("Soul Points: " + soulPoints);

        if (soulPoints <= 0)
        {
            GameOver();
        }
    }

    void GameOver()
    {
        gameOver = true;
        Debug.Log("You lost everything. Death wins.");
    }
}
